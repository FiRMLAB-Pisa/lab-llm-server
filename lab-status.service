[Unit]
Description=Lab LLM Status Dashboard (http://aleatico2.imago7.local:3002)
Documentation=https://github.com/<lab-org>/lab-llm-server
After=network.target ollama.service

[Service]
Type=simple
User=root
Group=root

ExecStart=/usr/bin/python3 /opt/lab-server/lab-status-server.py 3002

Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=lab-status

[Install]
WantedBy=multi-user.target
